# eBay Developer App ID (Client ID)
# Get yours at: https://developer.ebay.com/my/keys
EBAY_APP_ID=your-ebay-app-id-here

# Server port (default: 3001)
PORT=3001

# Scan interval in minutes (default: 120 = 2 hours)
SCAN_INTERVAL_MINUTES=120

# Maximum listings to keep in memory per scan
MAX_LISTINGS=500
